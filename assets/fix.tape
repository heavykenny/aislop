# aislop fix demo
# Run: vhs assets/fix.tape

Output assets/fix.gif

Set Shell "zsh"
Set Theme "Catppuccin Mocha"
Set FontFamily "Menlo"
Set FontSize 18
Set Width 1200
Set Height 600
Set Padding 30
Set LineHeight 1.4
Set LetterSpacing 0.5
Set TypingSpeed 40ms

Type "node dist/cli.js fix ../daily"
Sleep 500ms
Enter
Sleep 16s

Sleep 3s
